<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GitHub Stars Index | Archive</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Space+Mono:wght@400;700&family=Plus+Jakarta+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' rx='20' fill='black'/><path d='M50 15L61 41L87 50L61 59L50 85L39 59L13 50L39 41Z' fill='%23ff3e00'/></svg>">

    <style>
        :root {
            --bg: #080808;
            --fg: #ffffff;
            --fg-dim: #999999;
            --accent: #ff3e00; /* Industrial Orange */
            --accent-soft: rgba(255, 62, 0, 0.1);
            --surface: #121212;
            --border: #1f1f1f;
            --transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            --modal-overlay: rgba(0, 0, 0, 0.85);
            --glass: rgba(255, 255, 255, 0.03);
            --glass-border: rgba(255, 255, 255, 0.1);
        }

        [data-theme='light'] {
            --bg: #f5f5f5;
            --fg: #111111;
            --fg-dim: #666666;
            --accent: #ff3e00;
            --accent-soft: rgba(255, 62, 0, 0.05);
            --surface: #ffffff;
            --border: #dddddd;
            --modal-overlay: rgba(255, 255, 255, 0.7);
            --glass: rgba(0, 0, 0, 0.03);
            --glass-border: rgba(0, 0, 0, 0.1);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            background-color: var(--bg);
            color: var(--fg);
            font-family: 'Plus Jakarta Sans', sans-serif;
            line-height: 1.5;
            -webkit-font-smoothing: antialiased;
            overflow-x: hidden;
            min-height: 100vh;
        }

        /* Scanline & Noise Effect */
        body::before {
            content: "";
            position: fixed;
            inset: 0;
            background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.2) 50%), 
                        linear-gradient(90deg, rgba(255, 0, 0, 0.05), rgba(0, 255, 0, 0.02), rgba(0, 0, 255, 0.05));
            background-size: 100% 4px, 3px 100%;
            pointer-events: none;
            z-index: 1000;
            opacity: 0.1;
        }

        .container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 4rem 2rem;
        }

        @media (max-width: 768px) {
            .container { padding: 2rem 1rem; }
        }

        /* Header Enhancements */
        header {
            margin-bottom: 6rem;
            display: grid;
            grid-template-columns: 1.5fr 1fr;
            gap: 2rem;
            align-items: end;
        }

        .title-area h1 {
            font-family: 'Bebas Neue', sans-serif;
            font-size: clamp(3.5rem, 15vw, 10rem);
            line-height: 0.9;
            letter-spacing: -0.02em;
        }

        .header-stats {
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
            text-align: right;
            font-family: 'Space Mono', monospace;
        }

        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.6rem;
            font-size: 0.8rem;
            color: var(--accent);
            justify-content: flex-end;
        }

        .status-dot {
            width: 8px;
            height: 8px;
            background: var(--accent);
            border-radius: 50%;
            animation: pulse 1.5s infinite;
        }

        @keyframes pulse {
            0% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.5); opacity: 0.4; }
            100% { transform: scale(1); opacity: 1; }
        }

        .stats-grid {
            display: flex;
            justify-content: flex-end;
            gap: 2rem;
            font-size: 0.85rem;
            color: var(--fg-dim);
        }

        .stat-item b { color: var(--fg); }

        .top-langs {
            display: flex;
            gap: 0.8rem;
            justify-content: flex-end;
            flex-wrap: wrap;
        }

        .lang-tag {
            font-size: 0.7rem;
            background: var(--surface);
            padding: 0.2rem 0.6rem;
            border: 1px solid var(--border);
        }

        .header-links {
            display: flex;
            gap: 1.5rem;
            justify-content: flex-end;
            margin-top: 1rem;
            align-items: center;
        }

        .lang-toggle {
            cursor: pointer;
            padding: 0.2rem 0.5rem;
            border: 1px solid var(--border);
            font-size: 0.7rem;
            transition: var(--transition);
            background: var(--surface);
            color: var(--fg);
            font-family: 'Space Mono', monospace;
        }

        .lang-toggle:hover {
            border-color: var(--accent);
            color: var(--accent);
        }

        .header-links a {
            color: var(--fg);
            text-decoration: none;
            font-size: 0.8rem;
            border-bottom: 1px solid var(--border);
            transition: var(--transition);
        }

        .header-links a:hover {
            color: var(--accent);
            border-color: var(--accent);
        }

        .theme-toggle {
            cursor: pointer;
            padding: 0.2rem 0.5rem;
            border: 1px solid var(--border);
            font-size: 0.7rem;
            transition: var(--transition);
            background: var(--surface);
            color: var(--fg);
        }

        .theme-toggle:hover {
            border-color: var(--fg);
        }

        #clock {
            font-weight: 700;
            color: var(--fg);
        }

        @media (max-width: 900px) {
            header { 
                grid-template-columns: 1fr; 
                text-align: left; 
                gap: 1.5rem;
                margin-bottom: 3rem;
                padding-bottom: 2rem;
            }
            .header-stats, .stats-grid, .top-langs, .header-links, .status-badge { 
                justify-content: flex-start; 
                text-align: left; 
            }
            .header-stats { gap: 1rem; }
            .stats-grid { gap: 1rem; flex-wrap: wrap; }
            .header-links { flex-wrap: wrap; gap: 0.8rem; }
        }

        /* Search Section */
        .search-section {
            margin-bottom: 4rem;
            position: sticky;
            top: 1rem;
            z-index: 100;
        }

        .search-bar {
            background: var(--bg);
            backdrop-filter: blur(20px);
            border: 1px solid var(--border);
            padding: 0 1.5rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            min-height: 60px;
        }

        .search-hint {
            font-family: 'Space Mono', monospace;
            font-size: 0.7rem;
            color: var(--fg-dim);
            border: 1px solid var(--border);
            padding: 0.2rem 0.4rem;
            pointer-events: none;
        }

        #search-input {
            background: transparent;
            border: none;
            color: var(--fg);
            width: 100%;
            padding: 1rem 0;
            font-size: 1.1rem;
            font-family: 'Plus Jakarta Sans', sans-serif;
            letter-spacing: 0.05em;
            outline: none;
        }

        @media (max-width: 600px) {
            .search-hint { display: none; }
            #search-input { font-size: 1rem; }
        }
        
        #search-input::placeholder { color: var(--border); }

        /* Control Bar (Filter & Sort) */
        .controls-section {
            margin-bottom: 3rem;
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }

        .filter-bar {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
            align-items: center;
        }

        .dropdown {
            position: relative;
            font-family: 'Space Mono', monospace;
            font-size: 0.75rem;
        }

        .dropdown-trigger {
            background: var(--surface);
            border: 1px solid var(--border);
            color: var(--fg);
            padding: 0.6rem 1.2rem;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 0.8rem;
            transition: var(--transition);
        }

        .dropdown-trigger:hover {
            border-color: var(--fg);
        }

        .dropdown-content {
            position: absolute;
            top: 100%;
            left: 0;
            background: var(--surface);
            border: 1px solid var(--border);
            z-index: 500;
            width: 850px;
            max-width: calc(100vw - 40px);
            display: none;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            max-height: 450px;
            overflow: hidden;
            flex-direction: column;
            animation: fadeIn 0.2s ease-out;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @keyframes slideUp {
            from { transform: translateY(100%); }
            to { transform: translateY(0); }
        }

        #tag-dropdown .dropdown-content {
            left: 0;
            right: auto;
        }

        .dropdown.active .dropdown-content {
            display: flex;
        }

        .dropdown-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.6);
            backdrop-filter: blur(4px);
            z-index: 499;
            display: none;
        }

        body.dropdown-open .dropdown-overlay {
            display: block;
        }

        .dropdown-search-wrapper {
            padding: 1rem;
            border-bottom: 1px solid var(--border);
            background: var(--surface);
            position: sticky;
            top: 0;
            z-index: 2;
        }

        .dropdown-search {
            background: var(--bg);
            border: 1px solid var(--border);
            color: var(--fg);
            padding: 0.6rem 1rem;
            font-family: 'Space Mono', monospace;
            font-size: 0.85rem;
            outline: none;
            flex-grow: 1;
            width: 100%;
        }

        .dropdown-search-wrapper {
            display: flex;
            align-items: center;
            gap: 0.8rem;
            padding: 1rem;
            border-bottom: 1px solid var(--border);
            background: var(--surface);
            position: sticky;
            top: 0;
            z-index: 2;
        }

        .btn-clear-dropdown {
            font-size: 0.7rem;
            color: var(--accent);
            cursor: pointer;
            white-space: nowrap;
            padding: 0.2rem 0.5rem;
            border: 1px solid var(--accent);
            font-family: 'Space Mono', monospace;
            transition: var(--transition);
        }

        .btn-clear-dropdown:hover {
            background: var(--accent);
            color: var(--bg);
        }

        .dropdown-search:focus {
            border-color: var(--accent);
        }

        .dropdown-list {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
            overflow-y: auto;
            flex-grow: 1;
            border-top: 1px solid var(--border);
            border-left: 1px solid var(--border);
            border-right: 1px solid var(--border); /* Added right border to container */
        }

        .dropdown-item {
            padding: 0.6rem 0.8rem;
            cursor: pointer;
            transition: var(--transition);
            border-bottom: 1px solid var(--border);
            border-right: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 0.65rem;
            min-width: 0;
            color: var(--fg-dim);
        }

        .dropdown-item:hover {
            background: var(--surface-dim);
            color: var(--fg);
        }

        .dropdown-item.active {
            background: rgba(var(--accent-rgb), 0.1);
            color: var(--accent);
            border-bottom-color: var(--accent);
            font-weight: bold;
        }

        /* Removed static nth-child logic as columns are now dynamic */

        @media (max-width: 1024px) {
            .dropdown-content { 
                width: 600px;
            }
            .dropdown-list { grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); }
        }

        @media (max-width: 800px) {
            .dropdown-content {
                position: fixed;
                bottom: 0;
                top: auto;
                left: 0 !important;
                right: 0 !important;
                min-width: 100% !important;
                max-height: 80vh;
                z-index: 2000;
                border-top: 1px solid var(--accent);
                border-bottom: none;
                border-left: none;
                border-right: none;
                animation: slideUp 0.3s cubic-bezier(0.16, 1, 0.3, 1);
            }
            .dropdown-list { 
                grid-template-columns: 1fr;
                border-left: none;
            }
            .dropdown-item {
                font-size: 1rem;
                padding: 1rem 1.5rem;
                border-right: none !important;
                border-left: none !important;
            }
            .dropdown-search-wrapper {
                padding: 1.5rem;
            }
            .dropdown-search {
                padding: 0.8rem 1rem;
                font-size: 1rem;
            }
            body.dropdown-open {
                overflow: hidden;
            }
            .dropdown-close-mobile {
                display: block;
                text-align: center;
                padding: 0.8rem;
                font-size: 0.7rem;
                color: var(--fg-dim);
                letter-spacing: 0.2em;
                background: var(--surface);
                border-top: 1px solid var(--border);
            }
        }

        .dropdown-close-mobile { display: none; }

        .dropdown-item:hover {
            background: var(--glass);
            color: var(--accent);
        }

        .active-filters {
            display: flex;
            gap: 0.8rem;
            flex-wrap: wrap;
        }

        .filter-chip {
            background: var(--accent-soft);
            color: var(--accent);
            padding: 0.4rem 0.8rem;
            font-size: 0.7rem;
            font-family: 'Space Mono', monospace;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            border: 1px solid var(--accent);
        }

        .filter-chip span:hover { opacity: 1; }

        .filter-chip.reset-all {
            background: transparent;
            border-style: dashed;
            opacity: 0.8;
        }
        .filter-chip.reset-all:hover {
            opacity: 1;
            background: rgba(255, 68, 68, 0.1);
            border-color: #ff4444;
            color: #ff4444;
        }

        .sort-pill-group {
            display: flex;
            gap: 0.5rem;
            background: var(--surface);
            padding: 0.3rem;
            border: 1px solid var(--border);
            align-self: flex-start;
        }

        .sort-pill {
            padding: 0.4rem 1rem;
            font-size: 0.7rem;
            font-family: 'Space Mono', monospace;
            cursor: pointer;
            transition: var(--transition);
            color: var(--fg-dim);
        }

        .sort-pill.active {
            background: var(--fg);
            color: var(--bg);
        }

        /* Stats Bar Enhancements */
        .stats-dashboard {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 1.5rem;
            margin-bottom: 1rem;
        }

        @media (max-width: 768px) {
            .stats-dashboard {
                display: flex;
                gap: 0;
                background: var(--surface);
                border: 1px solid var(--border);
                margin-bottom: 0.5rem;
                padding: 0;
            }

            .stat-card {
                flex: 1;
                padding: 0.8rem 0.4rem;
                background: none;
                border: none;
                border-right: 1px solid var(--border);
                align-items: center;
                gap: 0.2rem;
            }

            .stat-card:last-child {
                border-right: none;
            }

            .stat-card-label {
                font-size: 0.55rem;
            }

            .stat-card-value {
                font-size: 0.9rem;
            }
            .stat-card-value .ui-stars {
                font-size: 0.9rem !important;
            }
            .stat-card-value .ui-stars svg {
                width: 14px;
                height: 14px;
            }
        }

        .stat-card:hover {
            border-color: var(--accent);
            background: rgba(255, 62, 0, 0.02);
        }

        .stat-card-label {
            font-family: 'Space Mono', monospace;
            font-size: 0.65rem;
            color: var(--fg-dim);
            text-transform: uppercase;
        }

        .stat-card-value {
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-weight: 700;
            font-size: 1.5rem;
        }

        .stat-card-value b { color: var(--accent); }

        /* Skeleton Loading */
        .skeleton {
            background: linear-gradient(90deg, var(--surface) 25%, var(--border) 50%, var(--surface) 75%);
            background-size: 200% 100%;
            animation: skeleton-loading 1.5s infinite;
        }

        @keyframes skeleton-loading {
            0% { background-position: 200% 0; }
            100% { background-position: -200% 0; }
        }

        /* Grid */
        .repo-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 2rem;
        }

        /* Unified UI Components */
        .ui-title {
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-weight: 600;
            word-break: break-all;
            color: var(--fg);
        }

        .ui-meta {
            font-family: 'Space Mono', monospace;
            font-size: 0.75rem;
            color: var(--fg-dim);
        }

        .ui-meta b { color: var(--fg); font-weight: 700; }
        .ui-meta .accent { color: var(--accent); }

        .ui-stars {
            color: var(--accent);
            font-weight: 700;
            display: inline-flex;
            align-items: center;
            gap: 0.3rem;
        }

        .ui-stars svg, .ui-stars .star-icon {
            transform: translateY(-1px);
        }

        .ui-tag {
            font-family: 'Space Mono', monospace;
            font-size: 0.7rem;
            padding: 0.2rem 0.6rem;
            border: 1px solid var(--border);
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            background: var(--surface);
            transition: var(--transition);
        }

        .repo-card {
            background: var(--surface);
            border: 1px solid var(--border);
            padding: 2rem;
            display: flex;
            flex-direction: column;
            cursor: pointer;
            transition: var(--transition);
            position: relative;
        }

        .repo-card:hover {
            border-color: var(--fg);
            transform: translateY(-5px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.5);
        }

        @media (max-width: 600px) {
            .repo-card { padding: 1.5rem; }
            .card-title { font-size: 1.5rem; }
        }

        .card-lang {
            margin-bottom: 1.5rem;
            color: var(--accent);
            border-color: var(--accent-soft);
        }

        .card-lang::before {
            content: "";
            width: 8px;
            height: 8px;
            background: var(--accent);
            border-radius: 50%;
        }

        .card-title {
            font-size: 1.25rem;
            margin-bottom: 1rem;
            line-height: 1.3;
        }

        .card-desc {
            font-size: 0.95rem;
            color: var(--fg-dim);
            margin-bottom: 2rem;
            flex-grow: 1;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
            line-height: 1.5;
        }

        .card-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-top: 1px solid var(--border);
            padding-top: 1.5rem;
        }

        /* Modal */
        .modal {
            position: fixed;
            inset: 0;
            background: var(--modal-overlay);
            backdrop-filter: blur(10px);
            z-index: 2000;
            display: none;
            opacity: 0;
            transition: opacity 0.3s ease;
            justify-content: center;
            align-items: center;
            padding: 2rem;
        }

        .modal.active { display: flex; opacity: 1; }

        .modal-content {
            background: var(--surface);
            border: 1px solid var(--border);
            max-width: 1000px;
            width: 100%;
            padding: 4rem;
            position: relative;
            transform: scale(0.95);
            transition: var(--transition);
            max-height: 90vh;
            overflow-y: auto;
        }

        .modal.active .modal-content { transform: scale(1); }

        .modal-close {
            position: absolute;
            top: 2rem;
            right: 2rem;
            background: none;
            border: none;
            color: var(--fg);
            font-family: 'Space Mono', monospace;
            cursor: pointer;
            font-size: 1rem;
        }

        .modal-close:hover { color: var(--accent); }

        .modal-title {
            font-size: 2.5rem;
            line-height: 1.2;
            margin-bottom: 1rem;
        }

        .modal-meta-group {
            display: flex;
            gap: 2rem;
            align-items: center;
            margin-bottom: 1.5rem;
        }

        .modal-section { margin-bottom: 3rem; }
        .section-label {
            font-family: 'Space Mono', monospace;
            font-size: 0.8rem;
            color: var(--accent);
            text-transform: uppercase;
            margin-bottom: 1rem;
            display: block;
        }

        .modal-desc {
            font-size: 1.1rem;
            line-height: 1.6;
            color: var(--fg-dim);
        }

        .modal-summary {
            font-size: 1.3rem;
            line-height: 1.6;
            color: var(--fg);
        }

        .topic-list {
            display: flex;
            flex-wrap: wrap;
            gap: 0.6rem;
        }

        .topic-tag {
            font-size: 0.75rem;
        }

        .modal-actions {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
        }

        .btn {
            display: block;
            padding: 1.5rem;
            text-align: center;
            text-decoration: none;
            font-family: 'Bebas Neue', sans-serif;
            font-size: 1.5rem;
            letter-spacing: 0.05em;
            transition: var(--transition);
        }

        .btn-primary { background: var(--fg); color: var(--bg); }
        .btn-secondary { border: 1px solid var(--fg); color: var(--fg); }
        .btn:hover { background: var(--accent); color: var(--bg); border-color: var(--accent); }

        /* Loader */
        #loading-trigger {
            height: 100px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Space Mono', monospace;
            font-size: 0.8rem;
            color: var(--border);
        }

        @media (max-width: 1100px) { .repo-grid { grid-template-columns: 1fr 1fr; } }
        @media (max-width: 600px) { 
            .repo-grid { grid-template-columns: 1fr; gap: 1rem; } 
            .container { padding-top: 2rem; }
            header { margin-bottom: 2rem; }
        }
        @media (max-width: 768px) { 
            .modal { padding: 0.5rem; }
            .modal-content { 
                padding: 2rem 1.5rem; 
                margin: auto;
                width: 100%;
                height: 100%;
                max-height: 100vh;
                border: none;
                border-radius: 0;
            }
            .modal-actions { grid-template-columns: 1fr; gap: 0.8rem; }
            .btn { padding: 1.2rem; font-size: 1.2rem; }
            .modal-title { font-size: 2.2rem; margin-top: 2rem; }
            .modal-close { top: 1rem; right: 1rem; padding: 0.5rem; z-index: 10;}
            .modal-header-info { flex-direction: column; gap: 1rem; }
            .modal-section { margin-bottom: 2rem; }
        }

        .modal-header-info {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
        }

        /* Footer */
        footer {
            margin-top: 10rem;
            padding: 4rem 0;
            border-top: 1px solid var(--border);
            font-family: 'Space Mono', monospace;
            font-size: 0.7rem;
            color: var(--fg-dim);
            letter-spacing: 0.05em;
        }

        .footer-grid {
            display: grid;
            grid-template-columns: 1fr 1.5fr 1fr;
            gap: 2rem;
            align-items: start;
        }

        .footer-brand .eof-text {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 2.5rem;
            color: var(--fg);
            line-height: 1;
            margin-bottom: 0.5rem;
            display: block;
        }

        .footer-center {
            text-align: center;
            border-left: 1px solid var(--border);
            border-right: 1px solid var(--border);
            padding: 0 2rem;
        }

        .footer-right {
            text-align: right;
        }

        .footer-tag {
            color: var(--accent);
            margin-top: 1rem;
            display: block;
        }

        @media (max-width: 768px) {
            .footer-grid { grid-template-columns: 1fr; text-align: left; }
            .footer-center { border: none; padding: 0; text-align: left; }
            .footer-right { text-align: left; }
        }
        /* Custom Scrollbar */
        ::-webkit-scrollbar {
            width: 10px;
        }
        ::-webkit-scrollbar-track {
            background: var(--bg);
        }
        ::-webkit-scrollbar-thumb {
            background: var(--border);
            border: 2px solid var(--bg);
            border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: var(--accent);
        }

        /* Back to Top Button */
        .back-to-top {
            position: fixed;
            bottom: 2rem;
            right: 2rem;
            width: 3.5rem;
            height: 3.5rem;
            background: var(--surface);
            border: 2px solid var(--border);
            color: var(--fg);
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: var(--transition);
            opacity: 0;
            visibility: hidden;
            z-index: 1000;
            backdrop-filter: blur(10px);
        }
        .back-to-top.visible {
            opacity: 1;
            visibility: visible;
        }
        .back-to-top:hover {
            border-color: var(--accent);
            color: var(--accent);
            transform: translateY(-5px);
        }
        @media (max-width: 768px) {
            .back-to-top {
                bottom: 1.5rem;
                right: 1.5rem;
                width: 3rem;
                height: 3rem;
            }
        }
    </style>
</head>
<body>
    <div class="dropdown-overlay" onclick="closeAllDropdowns()"></div>
    <div class="container">
        <header>
            <div class="title-area">
                <h1>Stars<br>Archive</h1>
            </div>
            <div class="header-stats">
                <div class="status-badge">
                    <div id="clock">00:00:00</div>
                    <span>UTC+0800</span>
                    <div class="status-dot"></div>
                </div>

                <div class="stats-dashboard" id="dashboard">
                    <div class="stat-card">
                        <span class="stat-card-label">TOTAL_ENTRIES</span>
                        <div class="stat-card-value" id="s-total">--</div>
                    </div>
                    <div class="stat-card">
                        <span class="stat-card-label">AVG_STARS</span>
                        <div class="stat-card-value" id="s-avg">--</div>
                    </div>
                    <div class="stat-card">
                        <span class="stat-card-label">TOP_STACK</span>
                        <div class="stat-card-value" id="s-top-stack">--</div>
                    </div>
                </div>

                <div class="header-links">
                    <button id="lang-btn" class="lang-toggle">LANG: ZH_CN</button>
                    <button id="theme-btn" class="theme-toggle">UI_THEME: NOIR_MODE</button>
                    <a href="https://github.com/iblogc/GithubStarsIndex" target="_blank">[ SOURCE_CODE ]</a>
                </div>
            </div>
        </header>

        <section class="search-section">
            <div class="search-bar">
                <input type="text" id="search-input" placeholder="SEARCH_KEYWORD_OR_TAG (AND_LOGIC)...">
                <div class="search-hint">PRESS [/] TO FOCUS</div>
            </div>
        </section>

        <section class="controls-section">
            <div class="filter-bar">
                <div class="dropdown" id="lang-dropdown">
                    <div class="dropdown-trigger">
                        <span id="l-lang-label">LANGUAGE: ALL</span>
                        <svg width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </div>
                    <div class="dropdown-content">
                        <div class="dropdown-search-wrapper">
                            <input type="text" class="dropdown-search" placeholder="FILTER..." id="lang-search">
                            <div class="btn-clear-dropdown" onclick="clearLangFilter()">[ CLEAR ]</div>
                        </div>
                        <div class="dropdown-list" id="lang-options"></div>
                        <div class="dropdown-close-mobile" onclick="closeAllDropdowns()">[ TAP_TO_CLOSE ]</div>
                    </div>
                </div>

                <div class="dropdown" id="topic-dropdown">
                    <div class="dropdown-trigger">
                        <span id="l-topic-label">TOPICS: ALL</span>
                        <svg width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </div>
                    <div class="dropdown-content">
                        <div class="dropdown-search-wrapper">
                            <input type="text" class="dropdown-search" placeholder="FILTER..." id="topic-search">
                            <div class="btn-clear-dropdown" onclick="clearTopicFilters()">[ CLEAR ]</div>
                        </div>
                        <div class="dropdown-list" id="topic-options"></div>
                        <div class="dropdown-close-mobile" onclick="closeAllDropdowns()">[ TAP_TO_CLOSE ]</div>
                    </div>
                </div>

                <div class="dropdown" id="tag-dropdown">
                    <div class="dropdown-trigger">
                        <span id="l-tag-label">TAGS: ALL</span>
                        <svg width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </div>
                    <div class="dropdown-content">
                        <div class="dropdown-search-wrapper">
                            <input type="text" class="dropdown-search" placeholder="FILTER..." id="tag-search">
                            <div class="btn-clear-dropdown" onclick="clearTagFilters()">[ CLEAR ]</div>
                        </div>
                        <div class="dropdown-list" id="tag-options"></div>
                        <div class="dropdown-close-mobile" onclick="closeAllDropdowns()">[ TAP_TO_CLOSE ]</div>
                    </div>
                </div>

                <div class="sort-pill-group">
                    <div class="sort-pill active" data-sort="pushed_at">LATEST</div>
                    <div class="sort-pill" data-sort="stars">STARS</div>
                    <div class="sort-pill" data-sort="full_name">A-Z</div>
                </div>
            </div>
            
            <div id="active-filters" class="active-filters"></div>
        </section>

        <main class="repo-grid" id="main-grid"></main>
        
        <div id="loading-trigger">System Loading...</div>

        <footer>
            <div class="footer-grid">
                <div class="footer-brand">
                    <span class="eof-text">EOF</span>
                    <span>End of trans stream // All systems nominal</span>
                </div>
                <div class="footer-center">
                    <p>This data is curated from GitHub and summarized by AI agents.</p>
                    <p>Repository indexed by {{ ai_model }} // Persistent storage active</p>
                </div>
                <div class="footer-right">
                    <span>© 2026 STARS ARCHIVE</span>
                    <span class="footer-tag">POWERED BY: JINJA2 // PYTHON // GITHUB</span>
                </div>
            </div>
        </footer>
        <button id="back-to-top" class="back-to-top" title="BACK_TO_TOP">
            <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="19" x2="12" y2="5"></line><polyline points="5 12 12 5 19 12"></polyline></svg>
        </button>
    </div>

    <!-- Details Modal -->
    <div id="details-modal" class="modal">
        <div class="modal-content">
            <button class="modal-close" onclick="closeModal()">[ ESC_CLOSE ]</button>
            
            <div class="modal-section modal-header-info">
                <div>
                    <div id="m-lang" class="ui-tag card-lang" style="margin-bottom: 1rem;"></div>
                    <h2 id="m-name" class="ui-title modal-title"></h2>
                    <div class="modal-meta-group ui-meta">
                        <div id="m-stars" class="ui-stars" style="font-size: 1.1rem;"></div>
                        <div id="m-updated"></div>
                    </div>
                    <div id="m-topics" class="topic-list"></div>
                </div>
            </div>

            <div class="modal-section">
                <span id="l-desc" class="section-label">DESCRIPTION</span>
                <p id="m-desc" class="modal-desc"></p>
            </div>

            <div class="modal-section">
                <span id="l-sum" class="section-label">AI_SUMMARY</span>
                <p id="m-summary" class="modal-summary"></p>
                <div id="m-tags" class="topic-list" style="margin-top: 1rem;"></div>
            </div>

            <div class="modal-actions">
                <a id="m-github" href="#" target="_blank" class="btn btn-primary">VIEW_ON_GITHUB</a>
                <a id="m-home" href="#" target="_blank" class="btn btn-secondary">VISIT_HOMEPAGE</a>
            </div>
        </div>
    </div>

    <script>
        // Data Injection
        const RAW_DATA = {{ repos|tojson }};
        
        let filteredData = [...RAW_DATA];
        let currentIndex = 0;
        let currentLang = localStorage.getItem('lang') || 'zh';
        const PAGE_SIZE = 24;

        // Filter State
        let activeLanguage = null;
        let activeTags = new Set();
        let activeTopics = new Set();
        let currentSort = 'pushed_at';

        const LANG_ALIAS = {
            'JavaScript': 'JS',
            'TypeScript': 'TS',
            'Objective-C': 'Obj-C',
            'Objective-C++': 'Obj-C++',
            'Jupyter Notebook': 'Jupyter',
            'CoffeeScript': 'Coffee',
            'PowerShell': 'PS',
            'Makefile': 'Make',
            'Batchfile': 'Batch',
            'Vim Snippet': 'Vim'
        };
        
        const grid = document.getElementById('main-grid');
        const trigger = document.getElementById('loading-trigger');
        const searchInput = document.getElementById('search-input');
        const modal = document.getElementById('details-modal');
        const langBtn = document.getElementById('lang-btn');
        const activeFiltersContainer = document.getElementById('active-filters');

        const I18N = {
            zh: {
                search: "搜索关键字或标签 (空格分隔多词 AND 搜索)...",
                updated: "更新时间",
                loading: "系统加载中...",
                end: "已加载全部档案",
                no_match: "未找到匹配项",
                orig_desc: "项目描述",
                ai_sum: "AI 摘要",
                no_sum: "暂无摘要可用。",
                github_btn: "前往 GitHub",
                home_btn: "访问项目官网",
                lang_all: "语言: 全部",
                tag_all: "标签: 全部",
                topic_all: "主题: 全部",
                latest: "最新更新",
                stars: "Star 数量",
                alpha: "字母顺序"
            },
            en: {
                search: "Search keywords or tags (space-separated AND search)...",
                updated: "Updated",
                loading: "Loading items...",
                end: "All records loaded",
                no_match: "No matching items",
                orig_desc: "Project Description",
                ai_sum: "AI Summary",
                no_sum: "No summary available.",
                github_btn: "View on GitHub",
                home_btn: "Visit Homepage",
                lang_all: "Language: All",
                tag_all: "Tags: All",
                topic_all: "Topics: All",
                latest: "Latest",
                stars: "Stars",
                alpha: "A-Z"
            }
        };

        function updateTexts() {
            const texts = I18N[currentLang];
            searchInput.placeholder = texts.search;
            langBtn.textContent = `LANG: ${currentLang === 'zh' ? 'ZH_CN' : 'EN_US'}`;
            
            document.getElementById('l-lang-label').textContent = activeLanguage ? `Language: ${activeLanguage}` : texts.lang_all;
            document.getElementById('l-tag-label').textContent = texts.tag_all;
            document.getElementById('l-topic-label').textContent = texts.topic_all;

            const sortPills = document.querySelectorAll('.sort-pill');
            sortPills[0].textContent = texts.latest;
            sortPills[1].textContent = texts.stars;
            sortPills[2].textContent = texts.alpha;

            applyFiltersAndSort();
        }

        // --- Data Processing & Stats ---
        function updateDashboard() {
            const total = RAW_DATA.length;
            const avgStars = Math.round(RAW_DATA.reduce((acc, curr) => acc + curr.stars, 0) / total);
            
            const langCounts = {};
            RAW_DATA.forEach(r => {
                if(r.language && r.language !== 'N/A') {
                    langCounts[r.language] = (langCounts[r.language] || 0) + 1;
                }
            });
            const topLangRaw = Object.entries(langCounts).sort((a,b) => b[1] - a[1])[0]?.[0] || 'N/A';
            const topLang = LANG_ALIAS[topLangRaw] || topLangRaw;

            document.getElementById('s-total').textContent = total;
            document.getElementById('s-avg').innerHTML = `<span class="ui-stars" style="font-size: 1.5rem;"><svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg> ${avgStars}</span>`;
            document.getElementById('s-top-stack').textContent = topLang;
        }

        function getUniqueTags() {
            const seen = new Map(); // lowercase -> original
            RAW_DATA.forEach(item => {
                const itemTags = currentLang === 'zh' ? 
                    (item.summary.tags_zh || item.summary.tags || []) : 
                    (item.summary.tags_en || item.summary.tags || []);
                itemTags.forEach(t => {
                    if (!t) return;
                    const clean = t.trim();
                    const key = clean.toLowerCase();
                    // Prioritize keeping the version with more uppercase/title case
                    if (!seen.has(key) || clean !== key) {
                        seen.set(key, clean);
                    }
                });
            });
            return Array.from(seen.values()).sort((a, b) => a.localeCompare(b));
        }

        function getUniqueLanguages() {
            const seen = new Map();
            RAW_DATA.forEach(item => {
                if (item.language && item.language !== 'N/A') {
                    const l = item.language.trim();
                    const key = l.toLowerCase();
                    if (!seen.has(key) || l !== key) {
                        seen.set(key, l);
                    }
                }
            });
            return Array.from(seen.values()).sort((a, b) => a.localeCompare(b));
        }

        function getUniqueTopics() {
            const seen = new Set();
            RAW_DATA.forEach(item => {
                (item.topics || []).forEach(t => {
                    if (t) seen.add(t);
                });
            });
            return Array.from(seen).sort((a, b) => a.localeCompare(b));
        }

        // --- UI Initialization ---
        let availableLangs = [];
        let availableTags = [];
        let availableTopics = [];

        function renderLangOptions(query = '') {
            const container = document.getElementById('lang-options');
            if (!container) return;
            const filtered = query ? availableLangs.filter(l => l.toLowerCase().includes(query.toLowerCase())) : availableLangs;
            
            // Fixed: Use activeLanguage check to properly highlight "ALL"
            let html = `<div class="dropdown-item ${activeLanguage === null ? 'active' : ''}" data-value="" style="grid-column: span 2;">All Languages</div>`;
            filtered.forEach(l => {
                const isActive = activeLanguage === l;
                html += `<div class="dropdown-item ${isActive ? 'active' : ''}" data-value="${l}">${l}</div>`;
            });
            container.innerHTML = html;
        }

        function renderTagOptions(query = '') {
            const container = document.getElementById('tag-options');
            if (!container) return;
            const filtered = query ? availableTags.filter(t => t.toLowerCase().includes(query.toLowerCase())) : availableTags;
            
            let html = '';
            filtered.forEach(t => {
                const isActive = activeTags.has(t);
                html += `<div class="dropdown-item ${isActive ? 'active' : ''}" data-value="${t}">#${t}</div>`;
            });
            container.innerHTML = html;
        }

        function renderTopicOptions(query = '') {
            const container = document.getElementById('topic-options');
            if (!container) return;
            const filtered = query ? availableTopics.filter(t => t.toLowerCase().includes(query.toLowerCase())) : availableTopics;
            
            let html = '';
            filtered.forEach(t => {
                const isActive = activeTopics.has(t);
                html += `<div class="dropdown-item ${isActive ? 'active' : ''}" data-value="${t}">${t}</div>`;
            });
            container.innerHTML = html;
        }

        function initControls() {
            updateDashboard();
            availableLangs = getUniqueLanguages();
            availableTags = getUniqueTags();
            availableTopics = getUniqueTopics();

            renderLangOptions();
            renderTagOptions();
            renderTopicOptions();

            document.getElementById('lang-search').oninput = (e) => renderLangOptions(e.target.value);
            document.getElementById('tag-search').oninput = (e) => renderTagOptions(e.target.value);
            document.getElementById('topic-search').oninput = (e) => renderTopicOptions(e.target.value);

            // Event Listeners
            document.querySelectorAll('.dropdown-trigger').forEach(trigger => {
                trigger.onclick = (e) => {
                    e.stopPropagation();
                    const current = trigger.parentElement;
                    const isActive = current.classList.contains('active');
                    
                    document.querySelectorAll('.dropdown').forEach(d => d.classList.remove('active'));
                    document.body.classList.remove('dropdown-open');

                    if(!isActive) {
                        current.classList.add('active');
                        document.body.classList.add('dropdown-open');
                    }
                };
            });

            // Prevent dropdown from closing when clicking inside content
            document.querySelectorAll('.dropdown-content').forEach(content => {
                content.onclick = (e) => e.stopPropagation();
            });

            document.getElementById('lang-options').onclick = (e) => {
                const item = e.target.closest('.dropdown-item');
                if(!item) return;
                activeLanguage = item.dataset.value || null;
                applyFiltersAndSort();
                if (window.innerWidth <= 800) closeAllDropdowns();
            };

            document.getElementById('tag-options').onclick = (e) => {
                const item = e.target.closest('.dropdown-item');
                if(!item) return;
                const val = item.dataset.value;
                if(activeTags.has(val)) activeTags.delete(val);
                else activeTags.add(val);
                applyFiltersAndSort();
            };

            document.getElementById('topic-options').onclick = (e) => {
                const item = e.target.closest('.dropdown-item');
                if(!item) return;
                const val = item.dataset.value;
                if(activeTopics.has(val)) activeTopics.delete(val);
                else activeTopics.add(val);
                applyFiltersAndSort();
            };

            document.querySelectorAll('.sort-pill').forEach(pill => {
                pill.onclick = () => {
                    document.querySelectorAll('.sort-pill').forEach(p => p.classList.remove('active'));
                    pill.classList.add('active');
                    currentSort = pill.dataset.sort;
                    applyFiltersAndSort();
                };
            });
        }

        function closeAllDropdowns() {
            document.querySelectorAll('.dropdown').forEach(d => d.classList.remove('active'));
            document.body.classList.remove('dropdown-open');
        }

        function clearLangFilter() {
            activeLanguage = null;
            applyFiltersAndSort();
        }

        function clearTagFilters() {
            activeTags.clear();
            applyFiltersAndSort();
        }

        function clearTopicFilters() {
            activeTopics.clear();
            applyFiltersAndSort();
        }

        function clearAllFilters() {
            activeLanguage = null;
            activeTags.clear();
            activeTopics.clear();
            applyFiltersAndSort();
        }

        function renderActiveFilters() {
            activeFiltersContainer.innerHTML = '';
            if(!activeLanguage && activeTags.size === 0) return;

            if(activeLanguage) {
                const chip = document.createElement('div');
                chip.className = 'filter-chip';
                chip.innerHTML = `Lang: ${activeLanguage} <span onclick="removeLang()">✕</span>`;
                activeFiltersContainer.appendChild(chip);
            }
            activeTags.forEach(tag => {
                const chip = document.createElement('div');
                chip.className = 'filter-chip';
                chip.innerHTML = `#${tag} <span onclick="removeTag('${tag}')">✕</span>`;
                activeFiltersContainer.appendChild(chip);
            });
            activeTopics.forEach(topic => {
                const chip = document.createElement('div');
                chip.className = 'filter-chip';
                chip.innerHTML = `${topic} <span onclick="removeTopic('${topic}')">✕</span>`;
                activeFiltersContainer.appendChild(chip);
            });

            // Reset All Button
            const resetBtn = document.createElement('div');
            resetBtn.className = 'filter-chip reset-all';
            resetBtn.style.cursor = 'pointer';
            resetBtn.innerHTML = `[ RESET_ALL ]`;
            resetBtn.onclick = clearAllFilters;
            activeFiltersContainer.appendChild(resetBtn);
        }

        function removeLang() { activeLanguage = null; applyFiltersAndSort(); }
        function removeTag(tag) { activeTags.delete(tag); applyFiltersAndSort(); }
        function removeTopic(topic) { activeTopics.delete(topic); applyFiltersAndSort(); }

        function applyFiltersAndSort() {
            const rawQuery = searchInput.value.trim().toLowerCase();
            const keywords = rawQuery ? rawQuery.split(/\s+/) : [];
            const texts = I18N[currentLang];
            
            filteredData = RAW_DATA.filter(item => {
                // Check if all keywords are matched (AND logic)
                const searchMatch = keywords.length === 0 || keywords.every(kw => {
                    const nameMatch = item.full_name.toLowerCase().includes(kw);
                    const descMatch = (item.description || '').toLowerCase().includes(kw);
                    const summaryMatch = (item.summary[currentLang] || '').toLowerCase().includes(kw);
                    return nameMatch || descMatch || summaryMatch;
                });
                
                const langMatch = !activeLanguage || item.language === activeLanguage;
                
                const itemTags = new Set(
                    (currentLang === 'zh' ? (item.summary.tags_zh || item.summary.tags || []) : (item.summary.tags_en || item.summary.tags || []))
                    .map(t => t.toLowerCase())
                );
                const tagMatch = activeTags.size === 0 || Array.from(activeTags).every(t => itemTags.has(t.toLowerCase()));
                
                const itemTopics = new Set((item.topics || []).map(t => t.toLowerCase()));
                const topicMatch = activeTopics.size === 0 || Array.from(activeTopics).every(t => itemTopics.has(t.toLowerCase()));

                return searchMatch && langMatch && tagMatch && topicMatch;
            });

            // Sorting
            filteredData.sort((a, b) => {
                if(currentSort === 'stars') return b.stars - a.stars;
                if(currentSort === 'full_name') return a.full_name.localeCompare(b.full_name);
                return b.updated_at.localeCompare(a.updated_at);
            });

            renderActiveFilters();
            
            grid.innerHTML = '';
            currentIndex = 0;
            loadMore();
            
            trigger.textContent = filteredData.length > 0 ? texts.loading : texts.no_match;
            
            // Fix shifting: Save scroll positions
            const tagContainer = document.getElementById('tag-options');
            const langContainer = document.getElementById('lang-options');
            const tagScrollTop = tagContainer ? tagContainer.scrollTop : 0;
            const langScrollTop = langContainer ? langContainer.scrollTop : 0;

            // Sync highlights in dropdowns
            renderLangOptions(document.getElementById('lang-search').value);
            renderTagOptions(document.getElementById('tag-search').value);
            renderTopicOptions(document.getElementById('topic-search').value);

            // Restore scroll positions
            const topicContainer = document.getElementById('topic-options');
            const topicScrollTop = topicContainer ? topicContainer.scrollTop : 0;

            if(tagContainer) tagContainer.scrollTop = tagScrollTop;
            if(langContainer) langContainer.scrollTop = langScrollTop;
            if(topicContainer) topicContainer.scrollTop = topicScrollTop;

            // Update labels
            document.getElementById('l-lang-label').textContent = activeLanguage ? `Language: ${activeLanguage}` : texts.lang_all;
        }

        // --- Render functions ---
        function createSkeleton() {
            const div = document.createElement('div');
            div.className = 'repo-card skeleton';
            div.style.height = '300px';
            return div;
        }

        function createCard(item) {
            const card = document.createElement('article');
            card.className = 'repo-card';
            const texts = I18N[currentLang];
            
            const summary = item.summary[currentLang] || item.summary.zh || texts.no_sum;
            
            card.innerHTML = `
                <div class="card-lang ui-tag">${item.language || 'DATA'}</div>
                <h2 class="card-title ui-title">${item.full_name}</h2>
                <p class="card-desc">${summary}</p>
                <div class="card-footer ui-meta">
                    <span class="ui-stars">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                        <span>${item.stars}</span>
                    </span>
                    <span>${texts.updated}: ${item.updated_at}</span>
                </div>
            `;
            card.onclick = () => openModal(item);
            return card;
        }

        function loadMore() {
            const texts = I18N[currentLang];
            if (currentIndex >= filteredData.length) {
                trigger.textContent = texts.end;
                return;
            }

            const fragment = document.createDocumentFragment();
            const end = Math.min(currentIndex + PAGE_SIZE, filteredData.length);
            
            for (let i = currentIndex; i < end; i++) {
                fragment.appendChild(createCard(filteredData[i]));
            }
            
            grid.appendChild(fragment);
            currentIndex = end;
            
            if (currentIndex >= filteredData.length) {
                trigger.textContent = texts.end;
            }
        }

        // Infinite Scroll
        const observer = new IntersectionObserver((entries) => {
            if (entries[0].isIntersecting) loadMore();
        }, { rootMargin: '400px' });

        observer.observe(trigger);

        searchInput.addEventListener('input', applyFiltersAndSort);

        // --- Initialization ---
        initControls();
        updateTexts();
        function openModal(item) {
            const texts = I18N[currentLang];
            document.getElementById('m-lang').textContent = item.language || 'DATA';
            document.getElementById('m-name').textContent = item.full_name;
            document.getElementById('m-stars').innerHTML = `
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                <span>${item.stars}</span>
            `;
            document.getElementById('m-updated').textContent = `${texts.updated}: ${item.updated_at}`;
            document.getElementById('m-desc').textContent = item.description || (currentLang === 'zh' ? '暂无项目描述。' : 'No original description.');
            
            document.getElementById('l-desc').textContent = texts.orig_desc;
            document.getElementById('l-sum').textContent = texts.ai_sum;
            
            document.getElementById('m-summary').textContent = item.summary[currentLang] || item.summary.zh;
            document.getElementById('m-github').textContent = texts.github_btn;
            document.getElementById('m-github').href = item.url;
            
            const homeBtn = document.getElementById('m-home');
            homeBtn.textContent = texts.home_btn;
            if (item.homepage) {
                homeBtn.href = item.homepage;
                homeBtn.style.display = 'block';
            } else {
                homeBtn.style.display = 'none';
            }

            // Topics
            const topicsContainer = document.getElementById('m-topics');
            topicsContainer.innerHTML = '';
            (item.topics || []).forEach(t => {
                const span = document.createElement('span');
                span.className = 'ui-tag topic-tag';
                span.textContent = t;
                topicsContainer.appendChild(span);
            });

            // AI Tags
            const tagsContainer = document.getElementById('m-tags');
            tagsContainer.innerHTML = '';
            
            const tagsField = currentLang === 'zh' ? 'tags_zh' : 'tags_en';
            const tags = item.summary[tagsField] || item.summary.tags || [];
            
            tags.forEach(t => {
                const span = document.createElement('span');
                span.className = 'ui-tag topic-tag';
                span.style.borderColor = 'var(--accent)';
                span.style.color = 'var(--accent)';
                span.textContent = `#${t}`;
                tagsContainer.appendChild(span);
            });

            modal.classList.add('active');
            document.body.style.overflow = 'hidden';
        }

        function closeModal() {
            modal.classList.remove('active');
            document.body.style.overflow = 'auto';
        }

        window.onclick = (e) => { 
            if (e.target == modal) closeModal();
            if (!e.target.closest('.dropdown')) closeAllDropdowns();
        }
        document.addEventListener('keydown', (e) => { 
            if (e.key === 'Escape') {
                closeModal();
                closeAllDropdowns();
            }
        });
        
        // Initial load
        loadMore();

        // Real-time Clock
        function updateClock() {
            const now = new Date();
            const timeStr = now.toLocaleTimeString('en-GB', { hour12: false });
            document.getElementById('clock').textContent = timeStr;
        }
        setInterval(updateClock, 1000);
        updateClock();

        // Keyboard Shortcut [/]
        document.addEventListener('keydown', (e) => {
            if (e.key === '/' && document.activeElement !== searchInput) {
                e.preventDefault();
                searchInput.focus();
            }
        });

        // Theme Toggle
        const themeBtn = document.getElementById('theme-btn');
        const setTheme = (theme) => {
            document.documentElement.setAttribute('data-theme', theme);
            localStorage.setItem('theme', theme);
            themeBtn.textContent = theme === 'dark' ? 'UI_THEME: NOIR_MODE' : 'UI_THEME: LIGHT_MODE';
        };

        themeBtn.addEventListener('click', () => {
            const currentTheme = document.documentElement.getAttribute('data-theme');
            setTheme(currentTheme === 'dark' ? 'light' : 'dark');
        });

        // Initialize theme from storage (Default: light)
        const savedTheme = localStorage.getItem('theme') || 'light';
        setTheme(savedTheme);

        // Language Toggle
        langBtn.addEventListener('click', () => {
            currentLang = currentLang === 'zh' ? 'en' : 'zh';
            localStorage.setItem('lang', currentLang);
            updateTexts();
        });

        // Back to Top Logic
        const backToTop = document.getElementById('back-to-top');
        window.addEventListener('scroll', () => {
            if (window.scrollY > 300) {
                backToTop.classList.add('visible');
            } else {
                backToTop.classList.remove('visible');
            }
        });
        backToTop.addEventListener('click', () => {
            window.scrollTo({ top: 0, behavior: 'smooth' });
        });

    </script>
</body>
</html>
